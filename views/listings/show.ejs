<% layout('layouts/boilerplate') %>


    <div class="row mt-3 ">
        <div class="col-8 offset-3 ">

       
    <h3 ><%=listing.title %></h3>
    </div>

    <div class="listings-card col-6 offset-3 show-card" >
  <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text"> Owned by : <i><%= listing.owner.username %></i> </p>
       <p class="card-text"> <%=listing.description %></p>
       <p class="card-text" ><%=listing.image %></p>
       <p class="card-text" >&#8377;<%=listing.price ?.toLocaleString("en-IN")||"N/A" %></p>
       <p class="card-text"> <%=listing.location %></p>
        <p class="card-text"><%=listing.country %></p>

    
  </div>
</div></div>

<% if(currUser && listing.owner._id.equals(currUser._id)){%>
   <div class="btns">
    <a href="/listings/<%= listing._id%>/edit" class="btn btn-dark mb-3 col-1 offset-3">Edit</a>
    <br><br>


    <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
     <button type="submit" class="btn btn-dark mb-3 del-btn  offset-5">Delete</button>
     </form>
      
    </div>
    <%}%>
   

    <div class="col-8 offset-3">
      <% if(currUser){%>
      <h4>Leave a Review</h4>
      <form action="/listings/<%=listing.id%>/reviews" method="post" novalidate class="needs-validation">
    <div class="mb-3 mt-3">
  <fieldset class="starability-basic">
 
  
  
  <input type="radio" id="second-rate1" name="review[rating]" value="1" />
  <label for="second-rate1" title="Terrible">1 star</label>
  <input type="radio" id="second-rate2" name="review[rating]" value="2" />
  <label for="second-rate2" title="Not good">2 stars</label>
  <input type="radio" id="second-rate3" name="review[rating]" value="3" />
  <label for="second-rate3" title="Average">3 stars</label>
  <input type="radio" id="second-rate4" name="review[rating]" value="4" />
  <label for="second-rate4" title="Very good">4 stars</label>
  <input type="radio" id="second-rate5" name="review[rating]" value="5" />
  <label for="second-rate5" title="Amazing">5 stars</label>
</fieldset></div>
    
    <div class="mb-3">
      <label for="comment">Commennts</label>
      <textarea
      name="review[comment]"
      id="comment"
      cols="30"
      rows="5"
      class="form-control"
      required></textarea><div class="invalid-feedback">Please give some comments</div></div>
      <button class="btn btn-outline-dark">submit</button>
      </form>
      <%}%>
      <hr>
      <p><b>All Reviews</b></p>
      <div class="row">
        <% for (review of listing.reviews){%>
         <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <p class="starability-result card-text mt-2" data-rating="<%=review.rating%>"></p>
            <h8 class="card-title"> @ <%= review.author.username%></h8>
             
              <p class="card-text"> <%=review.comment%></p>
             
                
                <form class="mb-3" method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                <button class="btn-sm btn-dark">Delete</button>

                
          </div>
         </div>
            
          
          

        <%}%>
      </div>
    </div>
    </div>
    <!-- <script src="/js/script.js"></script> -->
    
  

