<% layout('layouts/boilerplate') %>
<div class="col-8 offset-2">
    <h3 class="mt-3">Edit Your Listing</h3>
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT"
     
      class="needs-validation"
      enctype="multipart/form-data"
       novalidate>
      <div class="row mt-3" >

      <div class="mb-3">
  <label for="title" class="form-label"  >Title:</label>
  <input type="text" name="listing[title]" 
  class="form-control" required
   value="<%= listing.title%>">
   <div class="invalid-feedback">Title required</div>
  </div>

  <div class="mb-3">
  <label form="description" class="form-label"  >Description:</label>
  <textarea name="listing[description]" 
  class="form-control" required 
  value="<%=listing.description%>"><%=listing.description%></textarea></textarea>
  <div class="invalid-feedback">Description required</div>
  </div>

  <div class="mb-3" >
    <img src="<%= listing.image.url %>">
  </div>
   
  <div class="mb-3">
  <label form="imageURL" class="form-label"  >Upload new Image</label>
  <input type="file" name="listing[images]"
   class="form-control">
  </div>
<div class="row">
  <div class="mb-3 col-md-4">
  <label form="price" class="form-label"  >Price:</label>
  <input type="number" name="listing[price]"  class="form-control" required value="<%=listing.price%>">
  <div class="invalid-feedback">valid price required</div>
  </div>
 
  <div class="mb-3 col-md-8">
  <label form="Country" class="form-label"  >Country:</label>
  <input type="text" name="listing[country]" class="form-control" required value="<%=listing.country%>">
  <div class="invalid-feedback">country name required</div>
  </div>
  </div>


   <div class="mb-3">
  <label form="Location" class="form-label"  required>Location:</label>
  <input type="text" name="listing[location]" class="form-control" required value="<%=listing.location%>">
  <div class="invalid-feedback">location  required</div>
  </div>

  </div>
  <button type="submit" class="btn btn-dark mb-3 editBtn">Edit</button>
  

  </form>
 
</form>
</div>
<script src="/js/script.js"></script>


